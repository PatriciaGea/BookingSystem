MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
PORT=3000
CORS_ORIGINS=http://localhost:5173,https://patriciagea.github.io

# JWT - Chave secreta para assinatura de tokens
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# Email - Configuração do Gmail para envio de emails
# Para criar senha de aplicativo: https://myaccount.google.com/apppasswords
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_aplicativo_do_gmail

# Google OAuth
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
FRONTEND_URL=http://localhost:5173

